{
  "name": "claude-sdlc",
  "version": "2.2.0",
  "description": "Full SDLC governance for Claude Code — orchestrator, agent teams, workflow engine",
  "author": {
    "name": "Plan2Skill",
    "email": "plugins@plan2skill.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/plan2skill/plan2sdlc",
  "repository": "https://github.com/plan2skill/plan2sdlc",
  "keywords": ["sdlc", "governance", "workflow", "agents", "orchestrator"],
  "skills": "./skills/",
  "mcpServers": {
    "sdlc-registry": {
      "command": "node",
      "args": ["${CLAUDE_PLUGIN_ROOT}/mcp/registry/dist/server.js"],
      "env": {
        "REGISTRY_DB_PATH": "${CLAUDE_PLUGIN_DATA}/registry.sqlite",
        "SDLC_PROJECT_DIR": "${CLAUDE_PROJECT_DIR}"
      }
    }
  },
  "agents": [
    "./agents/orchestrator.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/entry-check.cjs"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-secrets-guard.cjs"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-write-guard.cjs"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/sdlc-superpowers-guard.cjs"
          }
        ]
      }
    ]
  }
}
