{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-sdlc.dev/schema/tech-debt.schema.json",
  "title": "SDLC Tech Debt Register",
  "description": "Tech debt tracking for the claude-sdlc plugin",
  "type": "object",
  "required": ["schemaVersion", "items", "metrics"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for migration support"
    },
    "items": {
      "type": "array",
      "items": { "$ref": "#/definitions/TechDebtItem" }
    },
    "metrics": {
      "$ref": "#/definitions/TechDebtMetrics"
    }
  },
  "definitions": {
    "TechDebtItem": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "domain",
        "severity",
        "type",
        "detected",
        "detectedBy",
        "effort",
        "impact",
        "proposedFix",
        "status",
        "linkedTasks"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^TD-\\d{3,}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "domain": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "type": {
          "type": "string",
          "enum": [
            "coupling",
            "complexity",
            "duplication",
            "obsolete",
            "performance",
            "security"
          ]
        },
        "detected": {
          "type": "string",
          "format": "date"
        },
        "detectedBy": {
          "type": "string"
        },
        "effort": {
          "type": "string",
          "enum": ["S", "M", "L", "XL"]
        },
        "impact": {
          "type": "string"
        },
        "proposedFix": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "open",
            "in-progress",
            "resolved",
            "accepted-risk",
            "wont-fix"
          ]
        },
        "linkedTasks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "resolvedDate": {
          "type": ["string", "null"],
          "format": "date"
        }
      }
    },
    "TechDebtMetrics": {
      "type": "object",
      "required": ["total", "open", "resolvedThisMonth", "trend"],
      "additionalProperties": false,
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0
        },
        "open": {
          "type": "integer",
          "minimum": 0
        },
        "resolvedThisMonth": {
          "type": "integer",
          "minimum": 0
        },
        "trend": {
          "type": "string",
          "enum": ["improving", "stable", "worsening"]
        }
      }
    }
  }
}
