{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://claude-sdlc.dev/schema/backlog.schema.json",
  "title": "SDLC Backlog",
  "description": "Backlog items tracked by the claude-sdlc plugin",
  "type": "object",
  "required": ["schemaVersion", "items"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for migration support"
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/BacklogItem"
      }
    }
  },
  "definitions": {
    "BacklogItem": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "type",
        "complexity",
        "status",
        "priority",
        "created",
        "updated",
        "domains",
        "tags",
        "sessions"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^TASK-\\d{3,}$",
          "description": "Unique task identifier in TASK-NNN format"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": ["feature", "bugfix", "refactor", "research", "docs", "ops"]
        },
        "complexity": {
          "type": "string",
          "enum": ["S", "M", "L", "XL"]
        },
        "domains": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "status": {
          "type": "string",
          "enum": [
            "inbox",
            "triaged",
            "planned",
            "executing",
            "reviewing",
            "done",
            "blocked",
            "abandoned"
          ]
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "unprioritized"]
        },
        "specPath": {
          "type": "string"
        },
        "planPath": {
          "type": "string"
        },
        "workflowId": {
          "type": "string"
        },
        "created": {
          "type": "string",
          "format": "date-time"
        },
        "updated": {
          "type": "string",
          "format": "date-time"
        },
        "sessions": {
          "type": "array",
          "items": { "$ref": "#/definitions/SessionRef" }
        },
        "estimatedCost": {
          "type": "number",
          "minimum": 0
        },
        "actualCost": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "SessionRef": {
      "type": "object",
      "required": ["sessionType", "timestamp", "result", "cost", "agentsUsed"],
      "additionalProperties": false,
      "properties": {
        "sessionType": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "result": {
          "type": "string",
          "enum": ["approved", "rejected", "needs-changes", "completed", "escalated"]
        },
        "cost": {
          "type": "number",
          "minimum": 0
        },
        "agentsUsed": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
